{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Design System para NirVana Pilates — academia de Pilates Reformer en Martínez, Buenos Aires. Concepto: Nirvana como pausa contemplativa. Reinterpretación minimalista del universo cosmos: mucho aire, vacío editorial, un astro como acento puntual.",
  "$metadata": {
    "version": "1.0.0",
    "lastUpdated": "2026-05-07",
    "client": "NirVana Pilates",
    "location": "Martínez, Buenos Aires",
    "author": "María Soledad Vila",
    "concept": "Pausa contemplativa. Cuerpo como camino. Vacío como lujo."
  },

  "color": {
    "$description": "Paleta cálida, terrenal, contemplativa. Crema y dorado como ejes, marrón cacao como ancla de autoridad para piezas técnicas.",

    "brand": {
      "primary":      { "$value": "#B8995A", "$type": "color", "$description": "Dorado mostaza — color de marca, titulares de identidad, acentos sobre fondos claros" },
      "primarySoft":  { "$value": "#D4BD8A", "$type": "color", "$description": "Dorado suavizado para hovers, gradientes y bordes activos" },
      "primaryDeep":  { "$value": "#8C7035", "$type": "color", "$description": "Dorado profundo para texto enfático sobre crema, énfasis tipográfico" },
      "primaryGlow":  { "$value": "rgba(184,153,90,0.10)", "$type": "color", "$description": "Halo / fondos de sección sutiles" },
      "primaryGlowStrong": { "$value": "rgba(184,153,90,0.20)", "$type": "color", "$description": "Halo más visible para destacados" }
    },

    "neutral": {
      "$description": "Base crema cálida. Evitar blancos puros — siempre con tinte cálido para sostener el universo de marca.",
      "bg":          { "$value": "#F5EFE4", "$type": "color", "$description": "Fondo principal — crema cálido, evoca papel artesanal" },
      "bgAlt":       { "$value": "#EBE2D2", "$type": "color", "$description": "Fondo secundario / secciones alternadas" },
      "bgCard":      { "$value": "#FFFCF6", "$type": "color", "$description": "Tarjetas y superficies elevadas — blanco con tinte crema, nunca puro" },
      "bgEditorial": { "$value": "#F0E8D8", "$type": "color", "$description": "Bloque editorial cálido para citas y testimonios" },
      "border":      { "$value": "#D8CDB8", "$type": "color", "$description": "Bordes definidos, color piedra cálida" },
      "borderLight": { "$value": "#E5DCC8", "$type": "color", "$description": "Bordes sutiles" },
      "text":        { "$value": "#2A2520", "$type": "color", "$description": "Texto principal — marrón muy oscuro casi negro, nunca negro puro" },
      "textDim":     { "$value": "#6B5F4E", "$type": "color", "$description": "Texto secundario, marrón cálido" },
      "textMuted":   { "$value": "#A89980", "$type": "color", "$description": "Texto deshabilitado, captions, metadata" }
    },

    "earth": {
      "$description": "Escala tierra-cacao. Para modo editorial-técnico (anatomía, autoridad, contenido educativo). Crea contraste sin perder calidez.",
      "tier1":       { "$value": "#E8DCC8", "$type": "color", "$description": "Más claro — tags suaves, fondos premium" },
      "tier2":       { "$value": "#C9B591", "$type": "color", "$description": "Intermedio claro — separadores, infografías" },
      "tier3":       { "$value": "#9A7F5C", "$type": "color", "$description": "Intermedio — destacados editoriales" },
      "tier4":       { "$value": "#5C4632", "$type": "color", "$description": "Profundo — títulos editoriales, autoridad técnica" },
      "tier5":       { "$value": "#2E2218", "$type": "color", "$description": "Cacao oscuro — modo dark, headers dramáticos" }
    },

    "atmosphere": {
      "$description": "Acentos atmosféricos, usar con MUCHA moderación. Solo en piezas aspiracionales/contemplativas, nunca en piezas técnico-educativas.",
      "moonGold":    { "$value": "#D4B062", "$type": "color", "$description": "Dorado luminoso para luna/astro acento" },
      "duskRose":    { "$value": "#C9A89A", "$type": "color", "$description": "Rosa polvoriento para atardecer/calidez extra" },
      "mist":        { "$value": "#D5CFC2", "$type": "color", "$description": "Bruma — degradados etéreos" },
      "deepNight":   { "$value": "#1F1810", "$type": "color", "$description": "Solo para portadas dramáticas modo nocturno" }
    },

    "semantic": {
      "$description": "Estados funcionales. Misma calidez que el resto, evitar saturación.",
      "success":     { "$value": "#7A8B5A", "$type": "color", "$description": "Verde oliva apagado — confirmaciones" },
      "warning":     { "$value": "#C49050", "$type": "color", "$description": "Ámbar terroso — avisos" },
      "danger":      { "$value": "#A85A4A", "$type": "color", "$description": "Terracota oscura — errores" },
      "info":        { "$value": "#7A8B95", "$type": "color", "$description": "Gris azulado polvoriento — informativo" }
    }
  },

  "typography": {
    "$description": "Mezcla: serif editorial (Cormorant Garamond) solo para titulares de marca y citas. Sans (Outfit) para body y UI — coherencia con el resto del sistema MSV.",
    "fontFamily": {
      "display":  { "$value": "'Cormorant Garamond', Georgia, serif", "$type": "fontFamily", "$description": "Solo titulares de marca, citas y piezas atmosféricas" },
      "body":     { "$value": "'Outfit', system-ui, sans-serif", "$type": "fontFamily", "$description": "Body, UI, navegación, captions — todo lo funcional" },
      "mono":     { "$value": "'JetBrains Mono', monospace", "$type": "fontFamily", "$description": "Código en showroom y documentación técnica" }
    },
    "fontWeight": {
      "displayRegular": { "$value": 400, "$type": "fontWeight" },
      "displayMedium":  { "$value": 500, "$type": "fontWeight" },
      "displaySemibold":{ "$value": 600, "$type": "fontWeight" },
      "bodyLight":      { "$value": 300, "$type": "fontWeight" },
      "bodyRegular":    { "$value": 400, "$type": "fontWeight" },
      "bodyMedium":     { "$value": 500, "$type": "fontWeight" },
      "bodySemibold":   { "$value": 600, "$type": "fontWeight" },
      "bodyBold":       { "$value": 700, "$type": "fontWeight" }
    },
    "fontSize": {
      "xs":   { "$value": "0.75rem",  "$type": "dimension", "$description": "12px — captions, metadata" },
      "sm":   { "$value": "0.875rem", "$type": "dimension", "$description": "14px — UI secundaria" },
      "base": { "$value": "1rem",     "$type": "dimension", "$description": "16px — body por defecto" },
      "md":   { "$value": "1.125rem", "$type": "dimension", "$description": "18px — body destacado, leads" },
      "lg":   { "$value": "1.375rem", "$type": "dimension", "$description": "22px — H4, intros editoriales" },
      "xl":   { "$value": "1.875rem", "$type": "dimension", "$description": "30px — H3" },
      "2xl":  { "$value": "2.5rem",   "$type": "dimension", "$description": "40px — H2 display" },
      "3xl":  { "$value": "3.5rem",   "$type": "dimension", "$description": "56px — H1 display" },
      "4xl":  { "$value": "5rem",     "$type": "dimension", "$description": "80px — hero gigante" }
    },
    "lineHeight": {
      "tight":   { "$value": 1.1,  "$type": "number", "$description": "Display, hero" },
      "snug":    { "$value": 1.25, "$type": "number", "$description": "Titulares" },
      "normal":  { "$value": 1.5,  "$type": "number", "$description": "Body" },
      "relaxed": { "$value": 1.7,  "$type": "number", "$description": "Body editorial / largas lecturas" }
    },
    "letterSpacing": {
      "tighter": { "$value": "-0.03em", "$type": "dimension", "$description": "Display Cormorant — la serif respira mejor con tracking negativo" },
      "tight":   { "$value": "-0.01em", "$type": "dimension" },
      "normal":  { "$value": "0",       "$type": "dimension" },
      "wide":    { "$value": "0.05em",  "$type": "dimension" },
      "wider":   { "$value": "0.1em",   "$type": "dimension", "$description": "Eyebrows uppercase" },
      "widest":  { "$value": "0.2em",   "$type": "dimension", "$description": "Tags pequeños tipo \"PILATES REFORMER · MARTÍNEZ\"" }
    }
  },

  "space": {
    "$description": "Escala de espaciado generosa. NirVana respira — el vacío es un activo de marca, no espacio sin usar.",
    "0":  { "$value": "0",       "$type": "dimension" },
    "1":  { "$value": "0.25rem", "$type": "dimension", "$description": "4px" },
    "2":  { "$value": "0.5rem",  "$type": "dimension", "$description": "8px" },
    "3":  { "$value": "0.75rem", "$type": "dimension", "$description": "12px" },
    "4":  { "$value": "1rem",    "$type": "dimension", "$description": "16px" },
    "5":  { "$value": "1.5rem",  "$type": "dimension", "$description": "24px" },
    "6":  { "$value": "2rem",    "$type": "dimension", "$description": "32px" },
    "7":  { "$value": "2.5rem",  "$type": "dimension", "$description": "40px" },
    "8":  { "$value": "3rem",    "$type": "dimension", "$description": "48px" },
    "9":  { "$value": "4rem",    "$type": "dimension", "$description": "64px" },
    "10": { "$value": "5rem",    "$type": "dimension", "$description": "80px" },
    "11": { "$value": "6rem",    "$type": "dimension", "$description": "96px — sección desktop" },
    "12": { "$value": "8rem",    "$type": "dimension", "$description": "128px — separación grande entre bloques" }
  },

  "radius": {
    "$description": "Bordes suaves pero NO pill. NirVana es contemplativa, no juguetona. Pill solo en CTAs de marca.",
    "none":   { "$value": "0",       "$type": "dimension" },
    "sm":     { "$value": "4px",     "$type": "dimension" },
    "base":   { "$value": "8px",     "$type": "dimension", "$description": "Inputs, tags" },
    "md":     { "$value": "12px",    "$type": "dimension", "$description": "Botones secundarios" },
    "lg":     { "$value": "16px",    "$type": "dimension", "$description": "Cards default" },
    "xl":     { "$value": "24px",    "$type": "dimension", "$description": "Hero cards, contenedores grandes" },
    "pill":   { "$value": "9999px",  "$type": "dimension", "$description": "Solo CTAs principales y tags atmosféricos" },
    "full":   { "$value": "100%",    "$type": "dimension", "$description": "Avatares, isotipo redondo" }
  },

  "shadow": {
    "$description": "Sombras cálidas, NUNCA grises puras. Tinte dorado-marrón, muy sutiles. NirVana = calma = sombras suaves.",
    "none":      { "$value": "none", "$type": "shadow" },
    "subtle":    { "$value": "0 2px 8px rgba(140,112,53,0.06)", "$type": "shadow", "$description": "Cards en reposo" },
    "soft":      { "$value": "0 8px 20px rgba(140,112,53,0.10)", "$type": "shadow", "$description": "Cards elevadas, hover" },
    "medium":    { "$value": "0 12px 32px rgba(140,112,53,0.14)", "$type": "shadow", "$description": "Modales, dropdowns" },
    "strong":    { "$value": "0 24px 60px rgba(46,34,24,0.20)", "$type": "shadow", "$description": "Hero portadas, dramatic" },
    "glow":      { "$value": "0 0 40px rgba(212,176,98,0.30)", "$type": "shadow", "$description": "Halo dorado para acento luna/astro" }
  },

  "motion": {
    "$description": "Animación lenta y respirada. NirVana no se apura. Usar curvas suaves, nunca bouncy.",
    "duration": {
      "instant": { "$value": "100ms", "$type": "duration" },
      "fast":    { "$value": "200ms", "$type": "duration" },
      "base":    { "$value": "350ms", "$type": "duration", "$description": "Transiciones por defecto, contemplativas" },
      "slow":    { "$value": "600ms", "$type": "duration", "$description": "Fade-in de sección" },
      "languid": { "$value": "1200ms","$type": "duration", "$description": "Animaciones atmosféricas, halos respirando" }
    },
    "easing": {
      "linear":   { "$value": "linear", "$type": "cubicBezier" },
      "ease":     { "$value": "cubic-bezier(0.4, 0, 0.2, 1)", "$type": "cubicBezier", "$description": "Default" },
      "easeOut":  { "$value": "cubic-bezier(0, 0, 0.2, 1)", "$type": "cubicBezier" },
      "easeIn":   { "$value": "cubic-bezier(0.4, 0, 1, 1)", "$type": "cubicBezier" },
      "breathe":  { "$value": "cubic-bezier(0.45, 0, 0.55, 1)", "$type": "cubicBezier", "$description": "Para halos pulsando — respiración" }
    }
  },

  "layout": {
    "$description": "Anchos máximos generosos pero nunca completos. NirVana respira en los márgenes.",
    "maxWidth": {
      "prose":     { "$value": "65ch",    "$type": "dimension", "$description": "Lectura cómoda" },
      "narrow":    { "$value": "720px",   "$type": "dimension" },
      "default":   { "$value": "1100px",  "$type": "dimension", "$description": "Contenedor estándar" },
      "wide":      { "$value": "1280px",  "$type": "dimension" },
      "full":      { "$value": "1440px",  "$type": "dimension" }
    },
    "breakpoints": {
      "sm": { "$value": "640px",  "$type": "dimension" },
      "md": { "$value": "768px",  "$type": "dimension" },
      "lg": { "$value": "1024px", "$type": "dimension" },
      "xl": { "$value": "1280px", "$type": "dimension" }
    }
  },

  "modes": {
    "$description": "Dos modos de aplicación de la marca. CRÍTICO: respetar el modo correcto según el tipo de pieza.",
    "atmosphere": {
      "$description": "MODO ATMÓSFERA — para piezas aspiracionales, contemplativas, de marca. Posts de Instagram tipo \"frase\", portadas de Reels, stories de mood.",
      "characteristics": [
        "Mucho aire — el vacío es protagonista (mínimo 60% del lienzo libre)",
        "Tipografía display Cormorant en peso regular o medium, italic permitido",
        "Un solo astro o elemento decorativo (luna creciente, estrella, sol bajito) usado como acento puntual",
        "Paleta: crema + dorado + un toque de moonGold o duskRose",
        "Tracking negativo en titulares grandes",
        "Sin íconos funcionales, sin CTAs visibles"
      ]
    },
    "editorial": {
      "$description": "MODO EDITORIAL-TÉCNICO — para piezas de autoridad, contenido educativo, anatomía, técnica. Carruseles informativos, infografías, lives.",
      "characteristics": [
        "Layout claro con jerarquías marcadas",
        "Tipografía: titular Cormorant + body Outfit (sin mezclar dos serifs)",
        "Paleta tierra (tier3, tier4) para autoridad — sin elementos cosmos",
        "Iconografía de línea fina dorada para jerarquizar puntos",
        "Espaciado funcional, no contemplativo",
        "Datos, números y referencias visibles y legibles"
      ]
    }
  }
}
